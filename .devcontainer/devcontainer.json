{
  "name": "TinyFarm",
  "image": "mcr.microsoft.com/devcontainers/java:1-17-bullseye",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}/TinyFarm",
  "forwardPorts": [
    8080
  ],
  "portsAttributes": {
    "8080": {
      "label": "TinyFarm",
      "onAutoForward": "openPreview"
    }
  },
  "containerEnv": {
    "SPRING_PROFILES_ACTIVE": "",
    "MAVEN_OPTS": "-Xmx1g"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic",
        "spring-boot.ls.java.home": "/usr/local/sdkman/candidates/java/current",
        "terminal.integrated.cwd": "/workspaces/${localWorkspaceFolderBasename}/TinyFarm"
      }
    },
    "codespaces": {
      "openFiles": [
        "README.md",
        "src/main/resources/application.yml"
      ]
    }
  },
  "postCreateCommand": "mvn -q -DskipTests compile",
  "postStartCommand": "chmod +x mvnw || true"
}
