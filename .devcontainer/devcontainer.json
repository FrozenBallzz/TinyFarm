{
  "name": "TinyFarm",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bullseye",
  "forwardPorts": [
    8080
  ],
  "portsAttributes": {
    "8080": {
      "label": "TinyFarm",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "redhat.vscode-yaml"
      ]
    }
  },
  "postCreateCommand": "mvn -q -DskipTests compile"
}
